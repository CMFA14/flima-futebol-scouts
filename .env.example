# Copie este arquivo para .env.local e preencha com suas credenciais
# cp .env.example .env.local

# Chave da API do Google Gemini (https://aistudio.google.com/app/apikey)
VITE_GEMINI_API_KEY=sua_chave_gemini_aqui

# URL do seu projeto Supabase (https://app.supabase.com → Settings → API)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima pública do Supabase (anon key)
VITE_SUPABASE_ANON_KEY=sua_chave_anon_supabase_aqui
